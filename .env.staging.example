# LiveMirror Staging Environment
# Copy to .env.staging and fill in values

# === Environment ===
ENVIRONMENT=staging
LOG_LEVEL=INFO
DEBUG=false

# === LLM API (Required) ===
LLM_API_KEY=${LLM_API_KEY}
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# === Zep Cloud (Required for knowledge graph) ===
ZEP_API_KEY=${ZEP_API_KEY}

# === Redis (Container internal) ===
REDIS_URL=redis://redis:6379

# === SelfMirror Execution ===
SELFMIRROR_EXECUTION_MODE=docker

# === Data Sources (Optional) ===
# SCRAPECREATORS_API_KEY=
# BRAVE_API_KEY=
# YOUTUBE_API_KEY=

# === Fusion Pipeline ===
USE_LEARNED_ATTENTION=true
USE_SPAM_SCORING=true
EMBEDDING_DIM=384

# === Fine-Tuning ===
FINE_TUNE_MIN_SAMPLES=10
FINE_TUNE_INTERVAL_HOURS=24
FINE_TUNE_ACCURACY_THRESHOLD=0.6
