# LiveMirror Environment Variables
# Copy to .env and fill in your keys

# === LLM API (Required) ===
# Supports any OpenAI-compatible API
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# === Zep Cloud (Required for knowledge graph) ===
ZEP_API_KEY=your_zep_api_key_here

# === Data Sources (Optional — each enables a platform) ===

# ScrapeCreators — covers Reddit, TikTok, Instagram
SCRAPECREATORS_API_KEY=

# X/Twitter — cookie-based auth
X_AUTH_TOKEN=
X_CT0=

# Bluesky
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# YouTube Data API
YOUTUBE_API_KEY=

# Web Search (pick one)
BRAVE_API_KEY=
PARALLEL_API_KEY=

# === Optional Services ===

# Polymarket (no key needed — public API)
# Hacker News (no key needed — public API)

# PostgreSQL (for prediction history)
DATABASE_URL=postgresql://localhost:5432/livemirror

# Redis (for caching / rate limiting)
REDIS_URL=redis://localhost:6379

# === Experimentation (Production Hardening) ===
# Shadow mode duplicates runs without affecting users
SHADOW_MODE_ENABLED=false

# A/B testing (only active when shadow mode is false)
AB_TEST_ENABLED=false
AB_TEST_SPLIT=0.20
AB_TEST_SEED=livemirror
# Optional overrides for candidate variant
# AB_CANDIDATE_AGENT_COUNT=30
# AB_CANDIDATE_SIMULATION_ROUNDS=48
